<svg xmlns="http://www.w3.org/2000/svg" width="400" height="250" viewBox="0 0 400 250">
  <defs>
    <linearGradient id="shopifyGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#96bf48;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7ab025;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="250" fill="url(#shopifyGrad)"/>
  <rect x="50" y="50" width="300" height="150" fill="#ffffff" opacity="0.1" rx="10"/>
  <text x="200" y="140" font-size="36" fill="#ffffff" text-anchor="middle" font-weight="bold" font-family="Arial">
    🛍️ Shopify
  </text>
  <text x="200" y="170" font-size="14" fill="#ffffff" text-anchor="middle" font-family="Arial">
    E-commerce
  </text>
</svg>
